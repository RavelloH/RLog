{
  "name": "rlog-js",
  "version": "3.0.0",
  "description": "Console-compatible TypeScript logging and stream capture for Node.js CLI tools and automation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage",
    "demo": "npm run build && node ./demo.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RavelloH/RLog.git"
  },
  "keywords": [
    "log",
    "output",
    "logger",
    "logging",
    "jsonl",
    "log-rotation",
    "stream-capture",
    "typescript"
  ],
  "author": "RavelloH",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/RavelloH/RLog/issues"
  },
  "homepage": "https://github.com/RavelloH/RLog#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  }
}
